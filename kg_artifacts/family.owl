<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/family#"
     xml:base="http://example.org/family"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://example.org/family"/>

    <!-- Classes -->
    <owl:Class rdf:about="http://example.org/family#Person">
        <rdfs:label>Person</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/family#OldPerson">
        <rdfs:label>OldPerson</rdfs:label>
        <rdfs:comment>A person older than 60 years</rdfs:comment>
    </owl:Class>

    <!-- Data Properties -->
    <owl:DatatypeProperty rdf:about="http://example.org/family#hasAge">
        <rdfs:domain rdf:resource="http://example.org/family#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>hasAge</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/family#hasName">
        <rdfs:domain rdf:resource="http://example.org/family#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>hasName</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Individuals -->
    <owl:NamedIndividual rdf:about="http://example.org/family#Alice">
        <rdf:type rdf:resource="http://example.org/family#Person"/>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alice</hasName>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">72</hasAge>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/family#Bob">
        <rdf:type rdf:resource="http://example.org/family#Person"/>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bob</hasName>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">45</hasAge>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/family#Carol">
        <rdf:type rdf:resource="http://example.org/family#Person"/>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Carol</hasName>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">68</hasAge>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/family#David">
        <rdf:type rdf:resource="http://example.org/family#Person"/>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">David</hasName>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">30</hasAge>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/family#Eve">
        <rdf:type rdf:resource="http://example.org/family#Person"/>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eve</hasName>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">85</hasAge>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/family#Frank">
        <rdf:type rdf:resource="http://example.org/family#Person"/>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Frank</hasName>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">55</hasAge>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/family#Grace">
        <rdf:type rdf:resource="http://example.org/family#Person"/>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Grace</hasName>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">61</hasAge>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/family#Henry">
        <rdf:type rdf:resource="http://example.org/family#Person"/>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Henry</hasName>
        <hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">15</hasAge>
    </owl:NamedIndividual>

</rdf:RDF>
